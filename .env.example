DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"
JWT_SECRET="replace-this-with-a-long-random-secret"

# Public app URL for emails and redirects
APP_BASE_URL="https://your-domain.com"

# Email delivery via Resend
RESEND_API_KEY="re_your_api_key"
MAIL_FROM="Club Manager <noreply@your-domain.com>"

# Telegram notifications
TELEGRAM_BOT_TOKEN="123456789:your_bot_token"
TELEGRAM_CHAT_ID="123456789"

# Toss Payments
NEXT_PUBLIC_TOSS_ENV="test"
NEXT_PUBLIC_TOSS_CLIENT_KEY="test_ck_your_client_key"
TOSS_SECRET_KEY="test_gsk_your_secret_key"
NEXT_PUBLIC_SUBSCRIPTION_AMOUNT="9900"
