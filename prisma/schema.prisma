datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Club {
  id                 Int      @id @default(autoincrement())
  name               String
  code               String   @unique
  publicJoinToken    String   @unique @default(cuid())
  subscriptionStatus String   @default("TRIAL")
  subscriptionEnd    DateTime?
  createdAt          DateTime @default(now())

  admins        Admin[]
  members       Member[]
  memberRequest MemberRequest[]
  payments      Payment[]
  sessions      ClubSession[]
  specialFees   SpecialFee[]
}

model Admin {
  id                 Int      @id @default(autoincrement())
  username           String   @unique
  password           String
  role               String   @default("ADMIN")
  status             String   @default("ACTIVE")
  mustChangePassword Boolean  @default(false)
  customFieldLabel   String   @default("차량번호") @map("custom1Label")
  createdAt          DateTime @default(now())

  clubId Int
  club   Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  passwordResetTokens PasswordResetToken[]
}

model Member {
  id                     Int      @id @default(autoincrement())
  name                   String
  gender                 String
  birth                  DateTime?
  phone                  String
  level                  String
  customFieldValue       String   @default("") @map("carnumber")
  note                   String   @default("")
  status                 String   @default("pending")
  createdAt              DateTime @default(now())
  deleted                Boolean  @default(false)
  deletedAt              DateTime?
  withdrawnAt            DateTime?

  clubId Int
  club   Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  fees                    Fee[]
  sessionParticipants     SessionParticipant[] @relation("SessionMember")
  hostedGuestParticipants SessionParticipant[] @relation("GuestHost")
  specialFeePayments      SpecialFeePayment[]
}

model MemberRequest {
  id               Int      @id @default(autoincrement())
  name             String
  gender           String
  birth            DateTime?
  phone            String
  level            String
  customFieldValue String   @default("") @map("carnumber")
  note             String   @default("")
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
  processedAt      DateTime?

  clubId Int
  club   Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model Fee {
  id       Int     @id @default(autoincrement())
  memberId Int
  year     Int
  month    Int
  paid     Boolean @default(false)

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, year, month])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  adminId Int
  admin   Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model Payment {
  id         Int      @id @default(autoincrement())
  orderId    String   @unique
  paymentKey String?
  amount     Int
  status     String
  method     String?
  orderName  String?
  createdAt  DateTime @default(now())

  clubId Int
  club   Club @relation(fields: [clubId], references: [id])
}

model SpecialFee {
  id          Int      @id @default(autoincrement())
  title       String
  amount      Int
  description String   @default("")
  dueDate     DateTime?
  createdAt   DateTime @default(now())

  clubId Int
  club   Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  payments SpecialFeePayment[]
}

model SpecialFeePayment {
  id        Int      @id @default(autoincrement())
  paid      Boolean  @default(false)
  paidAt    DateTime?
  note      String   @default("")
  createdAt DateTime @default(now())

  specialFeeId Int
  specialFee   SpecialFee @relation(fields: [specialFeeId], references: [id], onDelete: Cascade)

  memberId Int
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([specialFeeId, memberId])
}

model ClubSession {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @default("")
  location    String   @default("")
  publicToken String   @unique @default(cuid())
  date        DateTime
  startTime   String
  endTime     String
  capacity    Int?
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())

  clubId Int
  club   Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  participants SessionParticipant[]
}

model SessionParticipant {
  id               Int      @id @default(autoincrement())
  status           String   @default("REGISTERED")
  attendanceStatus String   @default("PENDING")
  checkedInAt      DateTime?
  createdAt        DateTime @default(now())
  guestName        String?

  sessionId Int
  session   ClubSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  memberId Int?
  member   Member? @relation("SessionMember", fields: [memberId], references: [id], onDelete: Cascade)

  hostMemberId Int?
  hostMember   Member? @relation("GuestHost", fields: [hostMemberId], references: [id], onDelete: SetNull)

  @@unique([sessionId, memberId])
}
